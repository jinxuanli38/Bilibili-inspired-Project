<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_creator_profile_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_chart_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#212121"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="近7天总粉丝" />

    <com.example.bilibili.widget.SimpleLineChartView
        android:id="@+id/chart_view"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tv_chart_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/creator_chart_no_increment_hint"
        android:textColor="@color/bili_text_grey"
        android:textSize="11sp"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
