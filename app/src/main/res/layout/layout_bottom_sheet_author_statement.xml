<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_bottom_sheet_bg"
    android:padding="16dp">

    <View
        android:id="@+id/view_handle"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@color/grey"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/author_statement"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_handle" />

    <TextView
        android:id="@+id/tv_confirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirm"
        android:textColor="#666666"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvSheet_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvSheet_title" />

    <TextView
        android:id="@+id/tv_sub_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="请选择符合您视频内容的创作声明"
        android:textColor="#999999"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@+id/tvSheet_title" />

    <RadioGroup
        android:id="@+id/rg_statement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/shape_tag_bg"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_sub_title">

        <RadioButton
            android:id="@+id/rb_original"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="#FF69B4"
            android:paddingStart="8dp"
            android:text="视频为自制"
            android:textColor="#333333"
            android:textSize="15sp"
            tools:ignore="RtlSymmetry" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="40dp"
            android:background="#F0F0F0" />

        <RadioButton
            android:id="@+id/rb_repost"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="#FF69B4"
            android:paddingStart="8dp"
            android:text="视频为转截"
            android:textColor="#333333"
            android:textSize="15sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_repost_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="#F7F7F7"
            android:padding="12dp"
            android:visibility="gone"> <TextView
            android:id="@+id/label_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="转载来源"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="转载会显示在视频播放的简介当中"
                android:textColor="#999999"
                android:textSize="11sp"
                app:layout_constraintBaseline_toBaselineOf="@id/label_source"
                app:layout_constraintStart_toEndOf="@id/label_source" />

            <EditText
                android:id="@+id/et_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@null"
                android:gravity="top"
                android:hint="注明视频来源网址、时间、地点"
                android:maxLength="200"
                android:minLines="2"
                android:textColor="#333333"
                android:textColorHint="#CCCCCC"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/label_source" />

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0/200"
                android:textColor="#999999"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_source" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </RadioGroup>

</androidx.constraintlayout.widget.ConstraintLayout>